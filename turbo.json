{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "build/**"],
      "inputs": ["src/**/*.tsx", "src/**/*.ts", "src/**/*.js", "package.json", "tsconfig.json"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "lint:package": {
      "dependsOn": ["^build", "build"],
      "inputs": ["dist/**", "package.json"],
      "outputs": []
    },
    "lint:types": {
      "dependsOn": ["^build", "build"],
      "inputs": ["dist/**", "package.json"],
      "outputs": []
    },
    "lint:packages": {
      "dependsOn": ["lint:package", "lint:types"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**/*.tsx", "src/**/*.ts", "test/**/*.ts", "package.json"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
