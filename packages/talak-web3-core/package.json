{
  "name": "@talak-web3/core",
  "version": "1.0.2",
  "type": "module",
  "author": "Dagim Abebe",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@talak-web3/auth": "1.0.4",
    "@talak-web3/config": "1.0.2",
    "@talak-web3/errors": "1.0.2",
    "@talak-web3/hooks": "1.0.3",
    "@talak-web3/middleware": "1.0.2",
    "@talak-web3/rpc": "1.0.2",
    "@talak-web3/types": "1.0.5"
  },
  "scripts": {
    "build": "tsup src/index.ts src/middleware.ts src/security.ts --format esm,cjs --clean --dts --outDir dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "node -e \"process.exit(0)\"",
    "lint:fix": "node -e \"process.exit(0)\"",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  }
}
